// Authorization schema for the record-chatter REBAC demo (test-only).
// @rebac_package: chatterdemo
// @rebac_package_version: 0.1.0
// @rebac_schema_revision: 1

// A gated threaded record whose post access diverges from write, so the F-v
// messaging tests can drive a poster who may change a tracked field (`write`) but
// not post comments (`post`): `writer` grants read+write yet not `post`, and `post`
// is owner/admin only. `reader` grants read without write. The record read (`read`)
// is the one gate every record-chatter surface rides (F-v parts 2/3), so an actor
// without it cannot reach the record's threads, messages, or activities.
definition chatterdemo/doc {
    relation owner: auth/user
    relation writer: auth/user
    relation reader: auth/user
    relation admin: angee/role // rebac:const=admin

    permission create = authenticated
    permission read   = owner + writer + reader + admin->member
    permission write  = owner + writer + admin->member
    permission post   = owner + admin->member
    permission delete = owner + admin->member
}
