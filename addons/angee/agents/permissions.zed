// Authorization schema for the agents addon.
// @rebac_package: agents
// @rebac_package_version: 0.1.0
// @rebac_schema_revision: 4

definition agents/agent {
    relation owner: auth/user // rebac:field=owner
    relation admin: angee/role // rebac:const=admin

    permission create = admin->member
    // The owner manages their own agent; platform admins reach all.
    permission read = owner + admin->member
    permission write = owner + admin->member
    permission delete = owner + admin->member
}

// Role namespace for tool bundles. A ToolRole is a table-less anchor object;
// membership is entirely tuple-backed. `includes` lets one bundle imply
// another, and the const-backed admin arm keeps platform administrators
// effective members without per-role tuples.
definition agents/toolrole {
    relation member: agents/agent | auth/user | auth/group#member | angee/role:admin#member
    relation includes: agents/toolrole#effective_member
    relation admin: angee/role // rebac:const=admin

    permission effective_member = member + includes + admin->member
}

// A tool grant is a pure tuple object whose id is
// `<mcp-server-sqid>.<FastMCP-tool-name>`. There is no grant row:
// Agent.mcp_tools mirrors direct selections into `grantee`, while role/group
// bundles write the same relation through the Permissions Hub. Server
// qualification keeps same-named tools on different servers independently
// grantable and revocable.
// Advertisement and execution intentionally check `use` only. `use_approved`
// is a separate standing-approval arm for a later consumer; the current
// requires_approval flag still drives the per-call workflow Decision flow.
//
// NEXT — scoped grants stay additive and consumer-owned. A downstream addon
// adds e.g. `vault_grantee` and `scope_vault` to this definition from its own
// permissions.extends.zed, then unions
// `vault_grantee & scope_vault->read` into `use`. It stores two tuples on
// `agents/tool_grant:<server-sqid>.<tool>.<vault-sqid>` (`#vault_grantee` and `#scope_vault`)
// and the runtime checks that scoped id. The scoped object deliberately has no
// base `grantee` tuple, so the unscoped arm below cannot bypass the scope.
// tests/extcontrib is the mechanical fragment recipe. V1 builds no scoped
// grant or scope relation.
definition agents/tool_grant {
    relation grantee: agents/agent | agents/toolrole#effective_member | auth/group#agent_member
    relation approver: auth/user
    relation admin: angee/role // rebac:const=admin

    // `grantee->effective_member` is redundant in SpiceDB userset semantics,
    // but makes the locked LocalBackend evaluate the allowed
    // toolrole#effective_member subject set (its direct-relation walker only
    // recurses into relations, while effective_member is a permission).
    permission use = grantee + grantee->effective_member + admin->member
    permission use_approved = (grantee & approver) + admin->member
}

definition agents/inference_provider {
    relation integration: integrate/integration // rebac:field=integration_ptr
    relation admin: angee/role // rebac:const=admin

    permission create = admin->member
    // Provider access derives from the parent integration; platform admins reach all.
    permission read = integration->read + admin->member
    permission write = integration->write + admin->member
    permission delete = integration->write + admin->member
}

definition agents/inference_model {
    relation provider: agents/inference_provider // rebac:field=provider
    relation admin: angee/role // rebac:const=admin

    permission create = admin->member
    permission read = provider->read + admin->member
    permission write = provider->write + admin->member
    permission delete = provider->write + admin->member
}

definition agents/skill {
    relation source: integrate/source // rebac:field=source
    relation admin: angee/role // rebac:const=admin

    permission create = admin->member
    // Skills are discovered under a source; access derives from it.
    permission read = source->read + admin->member
    permission write = source->write + admin->member
    permission delete = source->write + admin->member
}

definition agents/mcp_server {
    // Non-field relation mirrored from Agent.mcp_servers by agents.models m2m_changed.
    relation agent: agents/agent
    relation admin: angee/role // rebac:const=admin

    permission create = admin->member
    permission read = agent + admin->member
    permission write = admin->member
    permission delete = admin->member
}

definition agents/mcp_tool {
    relation server: agents/mcp_server // rebac:field=server
    relation admin: angee/role // rebac:const=admin

    permission create = admin->member
    permission read = server->read + admin->member
    permission write = server->write + admin->member
    permission delete = server->write + admin->member
}

definition agents/session {
    relation owner: auth/user // rebac:field=owner
    relation agent: agents/agent // rebac:field=agent
    relation admin: angee/role // rebac:const=admin

    permission create = agent->write + admin->member
    permission read = owner + admin->member
    permission write = owner + admin->member
    permission delete = owner + admin->member
}

definition agents/turn {
    relation session: agents/session // rebac:field=session

    permission create = session->write
    permission read = session->read
    permission write = session->write
    permission delete = session->write
}
