{
  "name": "@angee/ui",
  "version": "0.0.0",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./lib": {
      "types": "./src/lib/index.ts",
      "import": "./src/lib/index.ts"
    },
    "./lib/slot-outlet": {
      "types": "./src/lib/slot-outlet.tsx",
      "import": "./src/lib/slot-outlet.tsx"
    },
    "./lib/variant-context": {
      "types": "./src/lib/variant-context.tsx",
      "import": "./src/lib/variant-context.tsx"
    },
    "./lib/*": {
      "types": "./src/lib/*.ts",
      "import": "./src/lib/*.ts"
    },
    "./chrome/Glyph": {
      "types": "./src/chrome/Glyph.tsx",
      "import": "./src/chrome/Glyph.tsx"
    },
    "./chrome/AgentGlyph": {
      "types": "./src/chrome/AgentGlyph.tsx",
      "import": "./src/chrome/AgentGlyph.tsx"
    },
    "./chrome/AngeeMark": {
      "types": "./src/chrome/AngeeMark.tsx",
      "import": "./src/chrome/AngeeMark.tsx"
    },
    "./chrome/icon-registry": {
      "types": "./src/chrome/icon-registry.ts",
      "import": "./src/chrome/icon-registry.ts"
    },
    "./i18n": {
      "types": "./src/i18n/index.ts",
      "import": "./src/i18n/index.ts"
    },
    "./i18n/en": {
      "types": "./src/i18n/en.ts",
      "import": "./src/i18n/en.ts"
    },
    "./ui/widget-control": {
      "types": "./src/ui/widget-control.ts",
      "import": "./src/ui/widget-control.ts"
    },
    "./ui/*": {
      "types": "./src/ui/*.tsx",
      "import": "./src/ui/*.tsx"
    }
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@angee/refine": "workspace:*",
    "@angee/resources": "workspace:*",
    "@angee/sdk": "workspace:*",
    "@base-ui/react": "^1.5.0",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.17.0",
    "react-day-picker": "^10.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "happy-dom": "^20.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
