{
  "name": "@angee/ui",
  "version": "0.0.0",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./lib": {
      "types": "./src/lib/index.ts",
      "import": "./src/lib/index.ts"
    },
    "./lib/slot-outlet": {
      "types": "./src/lib/slot-outlet.tsx",
      "import": "./src/lib/slot-outlet.tsx"
    },
    "./lib/variant-context": {
      "types": "./src/lib/variant-context.tsx",
      "import": "./src/lib/variant-context.tsx"
    },
    "./lib/*": {
      "types": "./src/lib/*.ts",
      "import": "./src/lib/*.ts"
    },
    "./chrome/Glyph": {
      "types": "./src/chrome/Glyph.tsx",
      "import": "./src/chrome/Glyph.tsx"
    },
    "./chrome/AgentGlyph": {
      "types": "./src/chrome/AgentGlyph.tsx",
      "import": "./src/chrome/AgentGlyph.tsx"
    },
    "./chrome/AngeeMark": {
      "types": "./src/chrome/AngeeMark.tsx",
      "import": "./src/chrome/AngeeMark.tsx"
    },
    "./chrome/icon-registry": {
      "types": "./src/chrome/icon-registry.ts",
      "import": "./src/chrome/icon-registry.ts"
    },
    "./i18n": {
      "types": "./src/i18n/index.ts",
      "import": "./src/i18n/index.ts"
    },
    "./i18n/en": {
      "types": "./src/i18n/en.ts",
      "import": "./src/i18n/en.ts"
    },
    "./ui/widget-control": {
      "types": "./src/ui/widget-control.ts",
      "import": "./src/ui/widget-control.ts"
    },
    "./ui/*": {
      "types": "./src/ui/*.tsx",
      "import": "./src/ui/*.tsx"
    },
    "./widgets/index": {
      "types": "./src/widgets/index.ts",
      "import": "./src/widgets/index.ts"
    },
    "./widgets/codemirror-editor": {
      "types": "./src/widgets/codemirror-editor.ts",
      "import": "./src/widgets/codemirror-editor.ts"
    },
    "./widgets/date-format": {
      "types": "./src/widgets/date-format.ts",
      "import": "./src/widgets/date-format.ts"
    },
    "./widgets/label": {
      "types": "./src/widgets/label.ts",
      "import": "./src/widgets/label.ts"
    },
    "./widgets/markdown-codemirror": {
      "types": "./src/widgets/markdown-codemirror.ts",
      "import": "./src/widgets/markdown-codemirror.ts"
    },
    "./widgets/status-tones": {
      "types": "./src/widgets/status-tones.ts",
      "import": "./src/widgets/status-tones.ts"
    },
    "./widgets/types": {
      "types": "./src/widgets/types.ts",
      "import": "./src/widgets/types.ts"
    },
    "./widgets/*": {
      "types": "./src/widgets/*.tsx",
      "import": "./src/widgets/*.tsx"
    },
    "./feedback/index": {
      "types": "./src/feedback/index.ts",
      "import": "./src/feedback/index.ts"
    },
    "./feedback/error-message": {
      "types": "./src/feedback/error-message.ts",
      "import": "./src/feedback/error-message.ts"
    },
    "./feedback/refine-notification": {
      "types": "./src/feedback/refine-notification.ts",
      "import": "./src/feedback/refine-notification.ts"
    },
    "./feedback/use-busy-run": {
      "types": "./src/feedback/use-busy-run.ts",
      "import": "./src/feedback/use-busy-run.ts"
    },
    "./feedback/*": {
      "types": "./src/feedback/*.tsx",
      "import": "./src/feedback/*.tsx"
    }
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@angee/refine": "workspace:*",
    "@angee/resources": "workspace:*",
    "@angee/sdk": "workspace:*",
    "@base-ui/react": "^1.5.0",
    "@codemirror/commands": "^6.0.0",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@refinedev/core": "^5.0.12",
    "cmdk": "^1.1.1",
    "codemirror": "^6.0.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.17.0",
    "react-day-picker": "^10.0.1",
    "react-json-view-lite": "^2.5.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "happy-dom": "^20.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
