    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@angee/base": "workspace:*",
    "@angee/sdk": "workspace:*",
    "nuqs": "^2.5.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@storybook/addon-themes": "^10.1.0",
    "@storybook/react-vite": "^10.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.19.19",
    "storybook": "^10.1.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
