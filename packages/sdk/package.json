{
  "name": "@angee/sdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "codegen": "graphql-codegen --config codegen.ts && node ./bin/build-resource-types.mjs",
    "pretest": "pnpm codegen",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretypecheck": "pnpm codegen",
    "typecheck": "tsc --noEmit",
    "prebuild": "pnpm codegen",
    "build": "tsc --noEmit"
  },
  "peerDependencies": {
    "i18next": "^26.0.0",
    "react": "^19.0.0",
    "urql": "^5.0.0"
  },
  "dependencies": {
    "@urql/core": "^5.0.0",
    "@urql/exchange-graphcache": "^7.2.4",
    "graphql-ws": "^6.0.8"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.1.0",
    "@graphql-codegen/typescript": "^6.0.2",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "graphql": "^16.14.0",
    "happy-dom": "^16.0.0",
    "i18next": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "urql": "^5.0.0"
  }
}
