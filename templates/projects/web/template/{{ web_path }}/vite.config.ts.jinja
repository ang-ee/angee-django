import { fileURLToPath } from "node:url";
import { defineAngeeWebViteConfig } from "{{ framework_vite_shared }}";

// The framework owns the plugin pair, the dev-server host/port/proxy wiring, and
// the project-derived optimizeDeps set (see angee-django's `vite.shared.ts`).
// This config supplies only the two project facts: a downstream project consumes
// the `@angee/*` packages as installed (built) packages, so Vite pre-bundles
// them; and its `@angee/gql/<schema>` alias points at its OWN `runtime/gql/`.
export default defineAngeeWebViteConfig({
  prebundleAngeePackages: true,
  gqlRuntimeDir: fileURLToPath(new URL("../runtime/gql/", import.meta.url)),
});
