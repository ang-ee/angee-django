{
  "name": "{{ package_name }}",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "codegen": "angee-web-codegen --runtime ../runtime --web-root ."
  },
{# `@angee/metadata` and `@angee/refine` are direct dependencies even though the
   host imports neither by name: both own React contexts consumed across the
   host/addon boundary, and taking them directly is what makes Vite prebundle one
   shared module instance rather than embedding a copy inside each package that
   depends on them. A second copy is a second context. #}
  "dependencies": {
    "@angee/agents": "workspace:*",
    "@angee/app": "workspace:*",
    "@angee/iam": "workspace:*",
    "@angee/integrate": "workspace:*",
    "@angee/knowledge": "workspace:*",
    "@angee/messaging": "workspace:*",
    "@angee/metadata": "workspace:*",
    "@angee/operator": "workspace:*",
    "@angee/parties": "workspace:*",
    "@angee/platform": "workspace:*",
    "@angee/refine": "workspace:*",
    "@angee/resources": "workspace:*",
    "@angee/storage": "workspace:*",
    "@angee/ui": "workspace:*",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@tanstack/react-router": "^1.170.8",
    "react": "{{ react_version }}",
    "react-dom": "{{ react_version }}"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
