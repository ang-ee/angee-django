# Dev defaults; a deployment overrides each through the matching YAMLCONF_ env
# var (django-yamlconf). A plain YAMLCONF_SECRET_KEY replaces the string as-is;
# DEBUG and ALLOWED_HOSTS carry a `:jsonenv` marker so YAMLCONF_DEBUG /
# YAMLCONF_ALLOWED_HOSTS are JSON-decoded into a bool / list (see
# docs/backend/guidelines.md). The `:jsonenv` key is a marker, not a setting.
SECRET_KEY: {{ project_name }}-dev-key

DEBUG: true
DEBUG:jsonenv: true

ALLOWED_HOSTS:
  - "*"
ALLOWED_HOSTS:jsonenv: true

# {{ project_title }} composes the Angee base addons as its foundation —
# identity & permissions (iam), tiered data (resources), files (storage),
# connectors (integrate), partners (parties), messaging, OIDC login, platform,
# and the operator console — and adds its own capabilities as consumer addons
# under addons/{{ addon_namespace }}/*.
INSTALLED_APPS:
  - angee.iam
  - angee.resources
  - angee.storage
  - angee.integrate
  - angee.parties
  - angee.messaging
  - angee.iam_integrate_oidc
  - angee.platform
  - angee.operator
  # Consumer addons land here as they are built.
  # - {{ addon_namespace }}.example

ANGEE_ADDON_DIRS:
  - "{BASE_DIR}/addons"
ANGEE_RUNTIME_DIR: "{BASE_DIR}/runtime"
# Data lives under the dev-stack overlay `.angee/` (rendered by `angee init --dev`),
# so it matches the stack's `persist:` and stays out of the project source. The
# non-dev `local` stack bind-mounts its persist `./data` onto this default path.
ANGEE_DATA_DIR: "{BASE_DIR}/.angee/data"
