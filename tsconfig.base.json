{
  "compilerOptions": {
    // Framework-repo fixture wiring: base addon packages typecheck against the
    // notes example project's generated typed-document modules. A downstream
    // project's own web package should point `@angee/gql/*` at its runtime/gql.
    "paths": {
      "@angee/gql/*": ["./examples/notes-angee/runtime/gql/*"]
    },
    "target": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": []
  }
}
